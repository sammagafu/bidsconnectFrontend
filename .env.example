# Environment Configuration Example
# Copy this file to .env.local for local development
# Copy this file to .env.production for production builds

# Application Environment
# Options: development, production, staging
NODE_ENV=development

# API Configuration
# Base URL: e.g. http://localhost:8000/api/v1/ or https://bidsconnect.co.tz/api/v1/
# Backend CORS must allow this app origin (e.g. http://localhost:5173, https://bidsconnect.co.tz)
VITE_API_URL=https://bidsconnect.co.tz/api/v1/

# Application Configuration
# Base URL for the application
VITE_APP_URL=http://localhost:5173

# Application Name
VITE_APP_NAME=BidsConnect

# Debug Mode (optional)
# Set to true to enable additional logging in development
VITE_DEBUG=false

# Feature Flags (optional)
# Enable/disable specific features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
# Set to true when backend OAuth (Google, Facebook, GitHub) is implemented
VITE_ENABLE_SOCIAL_OAUTH=false

# Third-party Services (optional)
# Add your service keys here if using external services
# VITE_SENTRY_DSN=
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_STRIPE_PUBLIC_KEY=

# Notes:
# - All Vite env variables must be prefixed with VITE_ to be exposed to the client
# - Never commit .env.local or .env.production files with sensitive data
# - Use .env for default values that can be committed
# - Use .env.local for local development overrides (gitignored)
# - Use .env.production for production-specific values (gitignored)
